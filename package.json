{
  "name": "yuhuu",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "pnpm --filter @yuhuu/app start",
    "reset-project": "pnpm --filter @yuhuu/app reset-project",
    "android": "pnpm --filter @yuhuu/app android",
    "ios": "pnpm --filter @yuhuu/app ios",
    "android:dev": "pnpm --filter @yuhuu/app android:dev",
    "ios:dev": "pnpm --filter @yuhuu/app ios:dev",
    "web": "pnpm --filter @yuhuu/app web",
    "lint": "pnpm --filter @yuhuu/app lint",
    "lint:fix": "pnpm lint --fix",
    "lint:all": "pnpm -r run lint",
    "build": "pnpm --filter @yuhuu/app build",
    "build:packages": "pnpm -r --filter='./packages/*' --filter='!@yuhuu/app' --filter='!@yuhuu/tsconfig' --filter='!@yuhuu/eslint-config' run build",
    "dev:packages": "pnpm -r --filter='./packages/*' --filter='!@yuhuu/app' --filter='!@yuhuu/tsconfig' --filter='!@yuhuu/eslint-config' run dev",
    "clean:packages": "pnpm -r --filter='./packages/*' run clean",
    "typecheck": "tsc --build",
    "test": "pnpm --filter @yuhuu/app test",
    "test:all": "pnpm -r run test --forceExit",
    "test:watch": "pnpm --filter @yuhuu/app test:watch",
    "test:coverage": "pnpm --filter @yuhuu/app test:coverage"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@shopify/flash-list": "^2.2.0",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.5",
    "expo": "~54.0.32",
    "expo-blur": "~14.0.3",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.22",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "graphql": "^16.12.0",
    "i18next": "^25.8.13",
    "js-yaml": "^4.1.1",
    "jwt-decode": "^4.0.0",
    "nativewind": "^4.2.1",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-css-interop": "^0.2.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "urql": "^5.0.1"
  },
  "devDependencies": {
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.16",
    "typescript": "~5.9.2"
  },
  "pnpm": {
    "overrides": {
      "hermes-parser": "0.32.0",
      "babel-plugin-syntax-hermes-parser": "0.32.0"
    }
  },
  "private": true
}
