{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@yuhuu/storage": [
        "./packages/storage/src"
      ],
      "@yuhuu/http": [
        "./packages/http/src"
      ],
      "@yuhuu/i18n": [
        "./packages/i18n/src"
      ],
      "@yuhuu/auth": [
        "./packages/auth/src"
      ],
      "@yuhuu/components": [
        "./packages/components/src"
      ]
    }
  },
  "references": [
    {
      "path": "packages/storage"
    },
    {
      "path": "packages/http"
    },
    {
      "path": "packages/i18n"
    },
    {
      "path": "packages/auth"
    },
    {
      "path": "packages/components"
    }
  ],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "packages/*/dist",
    "packages/*/node_modules"
  ]
}