{
  "name": "@yuhuu/i18n",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "locales"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@yuhuu/storage": "workspace:*",
    "i18next": "^25.8.13",
    "react-i18next": "^16.5.4"
  },
  "peerDependencies": {
    "expo-localization": "*",
    "react": "*"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@yuhuu/tsconfig": "workspace:*",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~13.0.0",
    "jest": "^29.7.0",
    "tsup": "^8.0.0",
    "typescript": "~5.9.2"
  }
}
