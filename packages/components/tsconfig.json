{
  "extends": "@yuhuu/tsconfig/expo.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "paths": {
      "@/components/*": ["./src/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/constants/*": ["./src/constants/*"],
      "@/lib/i18n": ["../i18n/src"],
      "@/lib/authz": ["../auth/src/authz/authz"]
    }
  },
  "references": [
    {
      "path": "../i18n"
    },
    {
      "path": "../auth"
    }
  ],
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__"
  ]
}
