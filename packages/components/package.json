{
  "name": "@yuhuu/components",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./assets/*": "./assets/*"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests"
  },
  "peerDependencies": {
    "@expo/vector-icons": "*",
    "expo": "*",
    "expo-haptics": "*",
    "expo-symbols": "*",
    "nativewind": "*",
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": "*"
  },
  "dependencies": {
    "@yuhuu/auth": "workspace:*",
    "@yuhuu/i18n": "workspace:*",
    "@yuhuu/storage": "workspace:*",
    "@yuhuu/types": "workspace:*",
    "react-native-svg": "^15.15.3"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@yuhuu/tsconfig": "workspace:*",
    "babel-jest": "^29.7.0",
    "babel-preset-expo": "~13.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.16",
    "tsup": "^8.0.0",
    "typescript": "^5.3.3"
  }
}
